# "+" substitutes for `folder`
set mbox_type=Maildir
set folder=$HOME/.local/Mail/example1/
set record=+Sent
set postponed=+Drafts
set trash=+Trash
set spoolfile=+INBOX
set mail_check=2 # seconds
#sidebar config
unmailboxes *
mailboxes = +INBOX +Sent +Drafts +Trash +Junk

# smtp
set realname='John Doe'
set from=username@example1.com
set sendmail = "/usr/bin/msmtp -a example1"
